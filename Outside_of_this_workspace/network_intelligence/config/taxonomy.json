    "relationship_types": {
        "CHAMPION": {
            "description": "Has recommendation + endorsement + recent interaction",
            "requires": ["recommendation_or_endorsement", "recent_interaction"]
        },
        "ADVOCATE": {
            "description": "Has endorsement or recommendation (no recent interaction needed)",
            "requires": ["recommendation_or_endorsement"]
        },
        "ACTIVE_CONTACT": {
            "description": "Exchanged messages in last 90 days",
            "requires": ["message_within_90d"]
        },
        "WARM_CONTACT": {
            "description": "Exchanged messages in last 365 days",
            "requires": ["message_within_365d"]
        },
        "INBOUND_LEAD": {
            "description": "They sent inbound invite with message",
            "requires": ["inbound_invite_with_message"]
        },
        "DORMANT": {
            "description": "Connected > 1 year ago, no recent interaction",
            "requires": ["connected_over_1yr", "no_recent_interaction"]
        },
        "NEW_CONNECTION": {
            "description": "Connected < 90 days ago",
            "requires": ["connected_within_90d"]
        },
        "COLD": {
            "description": "No interaction data at all",
            "requires": ["no_interactions"]
        }
    },
    "engagement_levels": {
        "SUPER_ENGAGED": {"min_touchpoints": 3},
        "ENGAGED": {"min_touchpoints": 2},
        "LIGHT": {"min_touchpoints": 1},
        "PASSIVE": {"min_touchpoints": 0, "has_connection": true},
        "UNKNOWN": {"min_touchpoints": 0, "has_connection": false}
    }
}
