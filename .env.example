# ============================================================
# LinkedIn Post Generator - Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# All API keys are loaded dynamically from this single file.
# Change any key here and restart the server to apply.
# ============================================================

# ----------------------------------------------------------
# GOOGLE GEMINI (Required)
# ----------------------------------------------------------
# Main API key for all LLM and image generation calls
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Model names (defaults shown - override to use different models)
GEMINI_TEXT_MODEL=gemini-3-pro-preview
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ----------------------------------------------------------
# APIFY (Required for Viral/Competitor/YouTube research)
# ----------------------------------------------------------
# Primary Apify API key
APIFY_API_KEY=your_apify_api_key_here

# Optional: Additional Apify keys for rate-limit rotation (2-5)
# The system will try each key in order if the previous one fails
# APIFY_API_KEY_2=
# APIFY_API_KEY_3=
# APIFY_API_KEY_4=
# APIFY_API_KEY_5=

# ----------------------------------------------------------
# BASEROW (Required for Save/Approve functionality)
# ----------------------------------------------------------
BASEROW_URL=https://api.baserow.io
BASEROW_TOKEN=your_baserow_token_here

# Table IDs for data storage
BASEROW_TABLE_ID_GENERATED_CONTENT=your_table_id_here
BASEROW_TABLE_ID_COMPETITOR_POSTS=your_table_id_here

# ----------------------------------------------------------
# TAVILY (Required for web search / topic research)
# ----------------------------------------------------------
# Primary Tavily API key (used by jina_search.py and web_search.py)
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: Additional Tavily keys for rate-limit/credit rotation (2-5)
# The system tries each key in order if the previous one fails
# TAVILY_API_KEY_2=
# TAVILY_API_KEY_3=
# TAVILY_API_KEY_4=
# TAVILY_API_KEY_5=

# ----------------------------------------------------------
# JINA AI (Deprecated - kept for backward compatibility)
# ----------------------------------------------------------
JINA_API_KEY=your_jina_api_key_here

# ----------------------------------------------------------
# SUPABASE (Required for user auth, history, settings)
# ----------------------------------------------------------
# Get these from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key_here
# Anon (public) key — used for RLS-aware per-request clients
SUPABASE_ANON_KEY=your_anon_key_here

# ----------------------------------------------------------
# SECURITY & RATE LIMITING (Optional)
# ----------------------------------------------------------
# Comma-separated Supabase UIDs allowed to purge other users' data
# ADMIN_UIDS=uid1,uid2

# Comma-separated allowed CORS origins (defaults to Modal URL + localhost)
# CORS_ALLOWED_ORIGINS=https://tahir-70872--linkedin-post-generator-web.modal.run,http://localhost:9999

# Max requests per minute per user for generation endpoints (default: 10)
# Research endpoints use half this value (default: 5)
# RATE_LIMIT_RPM=10

# ----------------------------------------------------------
# SURVEILLANCE (Optional)
# ----------------------------------------------------------
# LinkedIn profile URL to monitor for performance analytics
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-profile/

# ----------------------------------------------------------
# PLACID (Optional - for carousel PDF generation)
# ----------------------------------------------------------
# Currently DEACTIVATED in generate_carousel.py
# Will be needed when carousel PDF generation is re-enabled
PLACID_API_KEY=your_placid_api_key_here

# ----------------------------------------------------------
# BLOTATO (Optional - for LinkedIn publishing/scheduling)
# ----------------------------------------------------------
# Used by the Drafts system to publish posts directly to LinkedIn
# Generate at: https://my.blotato.com/settings > API
BLOTATO_API_KEY=your_blotato_api_key_here

# Optional: ImgBB for alternative image hosting (free)
# IMGBB_API_KEY=your_imgbb_key_here
